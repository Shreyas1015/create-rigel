{
  "name": "rigel-typescript-template",
  "version": "0.0.1",
  "description": "Express + TypeScript + Sequelize Rigel template",
  "type": "module",
  "engines": {
    "node": ">=24",
    "npm": ">=11"
  },
  "scripts": {
    "dev": "tsx watch src/runtime/server.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/runtime/server.js",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest",
    "test:arch": "NODE_OPTIONS=--experimental-vm-modules jest tests/architecture/",
    "assert:tests": "NODE_OPTIONS=--experimental-vm-modules jest tests/architecture/ --json --outputFile=.rigel/.jest-count.json && node scripts/assert-tests-ran.mjs .rigel/.jest-count.json",
    "test:coverage": "NODE_OPTIONS=--experimental-vm-modules jest --coverage",
    "test:watch": "NODE_OPTIONS=--experimental-vm-modules jest --watch",
    "load:smoke": "k6 run tests/load/smoke.js",
    "load:stress": "k6 run tests/load/stress.js",
    "load:soak": "k6 run tests/load/soak.js",
    "lint": "eslint src/ --max-warnings=0",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "check:circular": "madge --circular src/ --extensions ts",
    "gate": "npm run typecheck && npm run lint && npm run check:circular && npm run test:arch && npm run assert:tests",
    "redgreen:record": "node scripts/redgreen-record.mjs",
    "ac:vector": "node scripts/ac-vector.mjs",
    "gate:final": "npm run gate && npm run ac:vector",
    "audit": "npm audit --omit=dev --audit-level=high",
    "openapi:export": "tsx scripts/openapi.export.ts",
    "db:migrate": "sequelize-cli db:migrate",
    "db:migrate:undo": "sequelize-cli db:migrate:undo",
    "db:seed": "sequelize-cli db:seed:all"
  },
  "keywords": [
    "express",
    "typescript",
    "sequelize",
    "rigel"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {},
  "devDependencies": {}
}
